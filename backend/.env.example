# Massive
MASSIVE_API_KEY=your-massive-api-key
MASSIVE_API_URL=https://api.massive.com

# Hub
HUB_HOST=::
HUB_PORT=3001
HUB_API_KEY=replace-with-a-long-random-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://default:password@host:6379

# Durable analytics storage
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
# Durable storage is enabled by default when DATABASE_URL exists.
# ENABLE_TIMESCALE=false
# DISABLE_DURABLE_STORE=true
DATA_QUALITY_GAP_THRESHOLD_MS=90000
DATA_QUALITY_SPIKE_THRESHOLD_PCT=0.25

# Security and rate limiting
HUB_ALLOWED_ORIGINS=http://localhost:3010
HUB_ADMIN_ALLOWED_ORIGINS=http://localhost:3010
HUB_PUBLIC_RATE_LIMIT_WINDOW_MS=60000
HUB_PUBLIC_RATE_LIMIT_MAX=240
HUB_ADMIN_RATE_LIMIT_WINDOW_MS=60000
HUB_ADMIN_RATE_LIMIT_MAX=60

# Job runtime
HUB_ENABLE_SCHEDULED_JOBS=true
HUB_BOOTSTRAP_FRONT_MONTHS_ON_STARTUP=true
HUB_BOOTSTRAP_SNAPSHOTS_ON_STARTUP=true
HUB_REBUILD_HOT_CACHE_ON_STARTUP=false

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Structured metric events are emitted as JSON logs in production and can be
# routed into Datadog or another log/metrics backend.
